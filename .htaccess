<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Let the /api folder pass through completely untouched.
  RewriteRule ^api/ - [L]

  # The root domain serves the static landing page.
  RewriteRule ^$ index.html [L]

  # Real files and directories, including static HTML and assets, are served directly.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Only extensionless clean URLs are routed to the SPA shell.
  # Missing file-like URLs such as /missing.html or /assets/missing.js stay real 404s.
  RewriteCond %{REQUEST_URI} !\.[^/]+$
  RewriteRule . /app.html [L]
</IfModule>
